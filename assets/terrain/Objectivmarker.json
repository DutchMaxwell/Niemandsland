      "LuaScript": "function onLoad()\r\n\tcircle = {\r\n\t\tcolor             = {250, 235, 215}, --RGB color of the circle\r\n\t\tradius            = 3,           --radius of the circle around the object\r\n\t\tsteps             = 32,          --number of segments that make up the circle\r\n\t\tthickness         = 0.25,         --thickness of the circle line\r\n\t\tvertical_position = 0.1,           --vertical height of the circle relative to the object\r\n\t}\r\n\r\n  self.setVectorLines({\r\n  \t\t{\r\n  \t\t\tpoints    = getCircleVectorPoints(circle.radius, circle.steps, circle.vertical_position),\r\n  \t\t\tcolor     = circle.color,\r\n  \t\t\tthickness = circle.thickness,\r\n  \t\t\trotation  = {0,0,0},\r\n  \t\t}\r\n  \t})\r\n\r\nend\r\n\r\nfunction getCircleVectorPoints(radius, steps, y)\r\n\tlocal t = {}\r\n\tlocal d,s,c,r = 360/steps, math.sin, math.cos, math.rad\r\n\tfor i = 0,steps do\r\n\t\ttable.insert(t, {\r\n\t\t\tc(r(d*i))*radius,\r\n\t\t\ty,\r\n\t\t\ts(r(d*i))*radius\r\n\t\t})\r\n\tend\r\n\treturn t\r\nend\r\n",
