*.log
logs/

# gdUnit4 test reports
reports/

# Tabletop Simulator imports (large files)
tts_imports/
*.tts.json
# TTS cache files
Images/
Models/

# Python
.venv/
venv/
__pycache__/
*.pyc
*.pyo
.pytest_cache/

# Fly.io (only relay/fly.toml is canonical)
/fly.toml

# Auto Claude data directory
.auto-claude/
.hf_token
.gemini_key
.r2_credentials
.trellis_space

# Model Forge artifacts (GLB-Optimizer-Backups, Gallery-Montagen)
*.orig-backup
/dao_union_gallery*.png

# Miniature GLBs are delivered on-demand from R2 (content-addressed, see model_manifest.json),
# never bundled. Keep them out of git AND out of builds (export_presets exclude_filter).
# The d6 dice model (assets/models/) is a core bundled asset and stays tracked.
assets/miniatures/*/glb/
# Model Forge scratch hero temp + stray backups that land in the miniatures tree.
# (NOT the tracked per-faction _reference*.png style inputs read by hero_workflow.py.)
assets/miniatures/*/_hero_tmp.png
assets/miniatures/*/*.tyranid_backup

# OPR data must NEVER be committed — it is OPR's content (not MIT-licensable) and
# is loaded exclusively via the Army Forge API at runtime.
assets/miniatures/*/units.json
assets/opr_samples/
examples/*.json

# Menu/UI render screenshots (review artifacts; generated by tools/render_menus.gd)
renders/
assets/.manifest_upload/

# Terrain GLBs + companion images are R2-delivered, never commit them
assets/terrain/grimdark_industrial/

# Biome battlemaps are R2-delivered (content-addressed, see assets/biome_manifest.json),
# never bundled. Keep the WebPs out of git AND out of builds; .biome_upload is build-only.
assets/terrain/biomes/*.webp
assets/.biome_upload/
# Ruin source/reference art is archived on R2 (terrain-source/ruins/), not bundled.
assets/terrain/props/ruins/
