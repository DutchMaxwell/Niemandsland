func test_unit_rules_of_primitive_resolves_data_aliases() -> void:
	# A synthetic map: "Plaguebound" aliases the Regeneration primitive at 6+; "Courage Aura"
	# aliases Banner. The layer must surface BOTH direct and item-granted rules, once each.
	RulesRegistry.reset_cache()
	RulesRegistry._cache["gf"] = {"factions": {"testfac": {
		"Plaguebound": {"primitive": "Regeneration", "params": {"ignore_target": 6, "all_models": true}},
		"Courage Aura": {"primitive": "Banner", "params": {"morale_bonus": 1}},
		"Fluffword": {"primitive": null},
	}}, "common": {}}
	var u := GameUnit.new()
	u.unit_properties = {"game_system": "gf", "faction_folder": "testfac",
		"special_rules": ["Plaguebound", "Fluffword", "Plaguebound"],
		"item_grants": {"Standard": ["Courage Aura"]}}
	var regen := RulesRegistry.unit_rules_of_primitive(u, "Regeneration")
	assert_int(regen.size()).is_equal(1)   # deduped
	assert_int(int(((regen[0] as Dictionary)["params"] as Dictionary)["ignore_target"])).is_equal(6)
	var banner := RulesRegistry.unit_rules_of_primitive(u, "Banner")
	assert_int(banner.size()).is_equal(1)  # item-granted counts
	assert_int(int(RulesRegistry.best_primitive_param(u, "Regeneration", "ignore_target", 5))).is_equal(6)
	assert_int(int(RulesRegistry.best_primitive_param(u, "Ravage", "wound_target", 6))).is_equal(6)  # absent family → fallback
	RulesRegistry.reset_cache()


func _inject_gf_map(fac: Dictionary) -> void:
	RulesRegistry.reset_cache()
	RulesRegistry._cache["gf"] = {"factions": {"testfac": fac}, "common": {}}


func test_regen_alias_params_flow_from_emitted_maps() -> void:
	# The REAL emitted map must carry the per-rule alias params (exporter precedence fix): a
	# Plaguebound unit regenerates at 6+, never at the Regeneration default 5+.
	RulesRegistry.reset_cache()
	var e := RulesRegistry.lookup("gf", "lust_disciples", "Lustbound")
	assert_str(str(e.get("primitive"))).is_equal("Royal Legion")
	assert_int(int((e.get("params", {}) as Dictionary).get("range_bonus_in", 0))).is_equal(4)
	var plague := RulesRegistry.lookup("gf", "plague_disciples", "Plaguebound")
	if plague.is_empty():   # faction slug probe — the rule lives in several chaos books
		for fac in ["plague_disciples", "wormhole_daemons_of_plague", "havoc_brothers"]:
			plague = RulesRegistry.lookup("gf", fac, "Plaguebound")
			if not plague.is_empty():
				break
	assert_bool(not plague.is_empty()).is_true()
	assert_int(int((plague.get("params", {}) as Dictionary).get("ignore_target", 0))).is_equal(6)
	RulesRegistry.reset_cache()


func test_second_wind_candidate_and_cap() -> void:
	_inject_gf_map({"Inquisitorial Agent": {"primitive": "Second Wind",
		"params": {"uses_per_game": 1, "army_cap_fraction": 3}}})
	var a := GameUnit.new()
	a.unit_id = "a"
	a.unit_properties = {"game_system": "gf", "faction_folder": "testfac", "player_id": 2,
		"special_rules": ["Inquisitorial Agent"], "name": "A", "quality": 4, "defense": 4}
	var m := ModelInstance.new()
	m.is_alive = true
	var n := Node3D.new()
	add_child(n)
	m.node = n
	a.models.append(m)
	a.is_activated = true
	var army: OPRArmyManager = auto_free(OPRArmyManager.new())
	army.game_units = {a.unit_id: a}
	army.current_round = 1
	var solo: SoloController = auto_free(SoloController.new())
	add_child(solo)
	solo.setup(army, null, null, 1, 2)
	var cand := solo.second_wind_candidate()
	assert_object(cand).is_equal(a)                       # activated carrier, unused → candidate
	assert_str(solo.spend_second_wind(a)).is_equal("Inquisitorial Agent")
	assert_bool(a.is_activated).is_false()                # may act again
	assert_bool(a.is_fatigued).is_false()                 # fatigue cleared per text
	a.is_activated = true
	assert_object(solo.second_wind_candidate()).is_null() # once per game — used
	RulesRegistry.reset_cache()


