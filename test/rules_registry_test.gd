	assert_int(int(RulesRegistry.param("aof", "mummified_undead", "Royal Legion", "range_bonus_in", 0))).is_equal(4)


func test_resistance_is_regeneration_family_with_spell_threshold() -> void:
	# Wave-5 coverage push (2026-07-17, "primitive families first" grill): Resistance = the Regeneration
	# family — ignore normal wounds on 6+, but SPELL wounds on a far more generous 2+ (official AoF/GF
	# text). This is the thin vertical slice that proves the full data pipeline end-to-end: source
	# registry -> text-free export -> committed map -> lookup. alien_hives is one gf book that fields it.
	assert_int(int(RulesRegistry.param("gf", "alien_hives", "Resistance", "ignore_target", 0))).is_equal(6)
	assert_int(int(RulesRegistry.param("gf", "alien_hives", "Resistance", "ignore_target_spell", 0))).is_equal(2)
	# Derived-modeled + system-scoped active for a bearer whose book actually fields it.
	assert_bool(RulesRegistry.modeled_tokens("gf").has("Resistance")).is_true()
	assert_bool(RulesRegistry.unit_rule_active(_unit_with(["Resistance"], "gf", "alien_hives"), "Resistance")).is_true()


func test_conditional_ap_family_resolves_target_property_params() -> void:
	# Wave-5 "primitive families first" (2026-07-18): the target-property AP rules each carry their own
	# {ap_bonus, condition, threshold} in the map, all consumed by the one AiCombatMath.conditional_ap_bonus
	# reader. Data-pipeline proof (source -> export -> map) for the conditional-AP family.
	assert_int(int(RulesRegistry.param("gf", "blood_prime_brothers", "Shatter", "ap_bonus", 0))).is_equal(2)
	assert_str(str(RulesRegistry.param("gf", "blood_prime_brothers", "Shatter", "condition", ""))).is_equal("vs_tough_ge")
	assert_int(int(RulesRegistry.param("gf", "custodian_brothers", "Tear", "threshold", 0))).is_equal(9)
	assert_bool(bool(RulesRegistry.param("gf", "blood_prime_brothers", "Melee Slayer", "charge_only", false))).is_true()
	assert_str(str(RulesRegistry.param("gf", "blessed_sisters", "Disintegrate", "condition", ""))).is_equal("vs_armor")
	# Piercing Assault: same reader, charge-gated condition (a reuse case, no new game code).
	assert_str(str(RulesRegistry.param("gf", "blessed_sisters", "Piercing Assault", "condition", ""))).is_equal("on_charge")
	assert_int(int(RulesRegistry.param("gf", "blessed_sisters", "Piercing Assault", "ap_bonus", 0))).is_equal(1)
	# Crack: on-6-to-hit AP bonus (a per-die effect; the Rending/Destructive machinery parametrised).
	assert_int(int(RulesRegistry.param("gf", "high_elf_fleets", "Crack", "on6_ap", 0))).is_equal(2)
	for r in ["Shatter", "Tear", "Melee Slayer", "Disintegrate", "Piercing Assault", "Crack"]:
		assert_bool(RulesRegistry.modeled_tokens("gf").has(r)).override_failure_message("%s not modeled" % r).is_true()
	# Melee Evasion (the melee-only Evasive) is also modeled + system-scoped.
	assert_bool(RulesRegistry.modeled_tokens("gf").has("Melee Evasion")).is_true()
	assert_int(int(RulesRegistry.param("gf", "dark_elf_raiders", "Melee Evasion", "hit_penalty", 0))).is_equal(1)
	# Precise (attacker-side flat +1 to hit).
	assert_bool(RulesRegistry.modeled_tokens("gf").has("Precise")).is_true()
	assert_int(int(RulesRegistry.param("gf", "alien_hives", "Precise", "hit_bonus", 0))).is_equal(1)
	# Fortified (defender-side incoming AP reduction).
	assert_bool(RulesRegistry.modeled_tokens("gf").has("Fortified")).is_true()
	assert_int(int(RulesRegistry.param("gf", "alien_hives", "Fortified", "incoming_ap_reduction", 0))).is_equal(1)
	# Rapid Rush (quick-win batch: +6" on Rush actions — bands via MovementRangeController).
	assert_bool(RulesRegistry.modeled_tokens("gf").has("Rapid Rush")).is_true()
	assert_int(int(RulesRegistry.param("gf", "battle_brothers", "Rapid Rush", "rush_mod", 0))).is_equal(6)
	# Steadfast (quick-win batch: byte-identical to Battleborn — round-start Shaken recovery on 4+).
	assert_bool(RulesRegistry.modeled_tokens("gf").has("Steadfast")).is_true()
	assert_int(int(RulesRegistry.param("gf", "custodian_brothers", "Steadfast", "recover_target", 0))).is_equal(4)
	# No Retreat (quick-win batch: failed Shaken/Rout test counts as passed, paid in 1-3 self-wounds).
	assert_bool(RulesRegistry.modeled_tokens("gf").has("No Retreat")).is_true()
	assert_int(int(RulesRegistry.param("gf", "alien_hives", "No Retreat", "self_wound_max", 0))).is_equal(3)
	assert_bool(bool(RulesRegistry.param("gf", "alien_hives", "No Retreat", "bypass_regen", false))).is_true()
	# Guarded (quick-win batch: +1 defense when shot/charged from over 9"). GFF prints no such rule —
	# its map must NOT automate it (source-driven scoping, no cross-system bleed).
	assert_bool(RulesRegistry.modeled_tokens("gf").has("Guarded")).is_true()
	assert_int(int(RulesRegistry.param("gf", "blessed_sisters", "Guarded", "defense_bonus", 0))).is_equal(1)
	assert_float(float(RulesRegistry.param("gf", "blessed_sisters", "Guarded", "over_in", 0.0))).is_equal_approx(9.0, 0.001)
	# Coverage wave: gff books alias the Guarded primitive now (Sturdy-family), so the TOKEN is
	# present there too — system scoping keeps holding at lookup level.
	assert_bool(RulesRegistry.modeled_tokens("gff").has("Guarded")).is_true()
	# Shrouding family (denial primitives): -6" shooting range / -3" charge movement, floored at 6".
	assert_float(float(RulesRegistry.param("gf", "custodian_brothers", "Ranged Shrouding", "range_penalty_in", 0.0))).is_equal_approx(6.0, 0.001)
	assert_float(float(RulesRegistry.param("gf", "custodian_brothers", "Ranged Shrouding", "floor_in", 0.0))).is_equal_approx(6.0, 0.001)
	assert_float(float(RulesRegistry.param("gf", "battle_brothers", "Melee Shrouding", "move_penalty_in", 0.0))).is_equal_approx(3.0, 0.001)
	for r in ["Ranged Shrouding", "Melee Shrouding"]:
		assert_bool(RulesRegistry.modeled_tokens("gf").has(r)).override_failure_message("%s not modeled" % r).is_true()
	# Data-lag closures: Versatile Attack + Infiltrate ran in code for waves already — the maps now
	# say so (kills their false "not automated — apply manually" notices).
	assert_int(int(RulesRegistry.param("gf", "battle_brothers", "Versatile Attack", "ap_bonus", 0))).is_equal(1)
	assert_float(float(RulesRegistry.param("gf", "battle_brothers", "Versatile Attack", "over_in", 0.0))).is_equal_approx(9.0, 0.001)
	assert_str(str(RulesRegistry.param("gf", "alien_hives", "Infiltrate", "counts_as", ""))).is_equal("Ambush")
	assert_float(float(RulesRegistry.param("gf", "alien_hives", "Infiltrate", "min_enemy_dist_in", 0.0))).is_equal_approx(3.0, 0.001)
	for r in ["Versatile Attack", "Infiltrate"]:
		assert_bool(RulesRegistry.modeled_tokens("gf").has(r)).override_failure_message("%s not modeled" % r).is_true()
	# Grill round 2 cut A: Unpredictable (the generic "when attacking" die — 1-3 AP(+1), 4-6 +1 hit).
	assert_int(int(RulesRegistry.param("gf", "alien_hives", "Unpredictable", "ap_bonus", 0))).is_equal(1)
	assert_int(int(RulesRegistry.param("gf", "alien_hives", "Unpredictable", "low_roll_max", 0))).is_equal(3)
	assert_bool(RulesRegistry.modeled_tokens("gf").has("Unpredictable")).is_true()
	# Sim-wave finding: an ALIASED rule (Ferocious -> Surge) must be modeled under its own NAME too —
	# the not-automated notice matches unit rule names, so a primitives-only set still printed it.
	assert_bool(RulesRegistry.modeled_tokens("gf").has("Ferocious")).is_true()
	assert_bool(RulesRegistry.modeled_tokens("gf").has("Surge")).is_true()
	# Unpredictable Shooter (autonomous wave): the shooting-only half of the attack die.
	assert_int(int(RulesRegistry.param("gf", "goblin_reclaimers", "Unpredictable Shooter", "ap_bonus", 0))).is_equal(1)
	assert_bool(RulesRegistry.modeled_tokens("gf").has("Unpredictable Shooter")).is_true()
	# Hit & Run halves (after-shoot only / after-melee only).
	assert_str(str(RulesRegistry.param("gf", "custodian_brothers", "Hit & Run Shooter", "after", ""))).is_equal("shoot")
	assert_str(str(RulesRegistry.param("gf", "alien_hives", "Hit & Run Fighter", "after", ""))).is_equal("melee")
	# Range-gated conditional AP (Piercing Hunter / Slayer).
	assert_str(str(RulesRegistry.param("gf", "blessed_sisters", "Piercing Hunter", "condition", ""))).is_equal("ranged_over")
	assert_str(str(RulesRegistry.param("gf", "dao_union", "Slayer", "gate", ""))).is_equal("ranged_over_or_charge")
	# Heavy Impact(X): rated second impact pool at AP(1).
	assert_int(int(RulesRegistry.param("gf", "ratmen_clans", "Heavy Impact", "ap", 0))).is_equal(1)
	# Ravage(X): direct wounds on 6+ during the bearer's melee turn (rated, no save).
	assert_int(int(RulesRegistry.param("gf", "alien_hives", "Ravage", "wound_target", 0))).is_equal(6)
	assert_bool(bool(RulesRegistry.param("gf", "alien_hives", "Ravage", "no_save", false))).is_true()
	assert_bool(RulesRegistry.modeled_tokens("gf").has("Ravage")).is_true()
	# Quick Shot: shoot after Rush (decision-level band swap).
	assert_bool(bool(RulesRegistry.param("gf", "goblin_reclaimers", "Quick Shot", "shoot_after_rush", false))).is_true()
	assert_bool(RulesRegistry.modeled_tokens("gf").has("Quick Shot")).is_true()
	# Mend: pre-attack D3 heal on a friendly Tough model within 3".
	assert_float(float(RulesRegistry.param("gf", "battle_brothers", "Mend", "range_in", 0.0))).is_equal_approx(3.0, 0.001)
	assert_bool(RulesRegistry.modeled_tokens("gf").has("Mend")).is_true()
	# Breath Attack: pre-attack 2+ for one Blast(3)/AP(1) hit at 6"/LOS.
	assert_int(int(RulesRegistry.param("gf", "alien_hives", "Breath Attack", "blast", 0))).is_equal(3)
	assert_bool(RulesRegistry.modeled_tokens("gf").has("Breath Attack")).is_true()
	# Repel Ambushers: enemy Ambushers must arrive over 12" away from the bearer's unit.
	assert_float(float(RulesRegistry.param("gf", "human_defense_force", "Repel Ambushers", "min_dist_in", 0.0))).is_equal_approx(12.0, 0.001)
	assert_bool(RulesRegistry.modeled_tokens("gf").has("Repel Ambushers")).is_true()
	# Movement trio (cut C): Bounding / Teleport / Hit & Run.
	assert_float(float(RulesRegistry.param("gf", "eternal_dynasty", "Teleport", "rush_bonus_in", 0.0))).is_equal_approx(6.0, 0.001)
	assert_float(float(RulesRegistry.param("gf", "custodian_brothers", "Hit & Run", "move_in", 0.0))).is_equal_approx(3.0, 0.001)
	for r in ["Bounding", "Teleport", "Hit & Run"]:
		assert_bool(RulesRegistry.modeled_tokens("gf").has(r)).override_failure_message("%s not modeled" % r).is_true()
	# Wahl-effect wave: Versatile Reach (+4" range OR +2" charge) and Versatile Defense (def half
	# played consistently — Guarded machinery; default_mode is data for the future EV switch).
	assert_float(float(RulesRegistry.param("gf", "battle_brothers", "Versatile Reach", "range_bonus_in", 0.0))).is_equal_approx(4.0, 0.001)
	assert_float(float(RulesRegistry.param("gf", "battle_brothers", "Versatile Reach", "charge_bonus_in", 0.0))).is_equal_approx(2.0, 0.001)
	assert_str(str(RulesRegistry.param("gf", "change_disciples", "Versatile Defense", "default_mode", ""))).is_equal("def")
	for r in ["Versatile Reach", "Versatile Defense"]:
		assert_bool(RulesRegistry.modeled_tokens("gf").has(r)).override_failure_message("%s not modeled" % r).is_true()
	# Vanguard: post-deploy 9" placement (pushed toward the enemy side by the AI).
	assert_float(float(RulesRegistry.param("gf", "dark_elf_raiders", "Vanguard", "place_in", 0.0))).is_equal_approx(9.0, 0.001)
	assert_bool(RulesRegistry.modeled_tokens("gf").has("Vanguard")).is_true()


