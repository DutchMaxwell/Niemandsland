## Resolver wave A (2026-07-24): the 17 planned combat mechanics flipped to automated — the
## EMITTED maps must resolve them with primitive + params intact (real book/faction pairs).
func test_wave_a_flipped_rules_resolve_from_emitted_maps() -> void:
	var cases: Array = [
		["gf", "human_inquisition", "Takedown Shot", "Takedown", "extra_attack_q", 2],
		["gf", "alien_hives", "Takedown Strike", "Takedown", "ap", 2],
		["gf", "orc_marauders", "Rending Mark", "Utility Buff", "vs_target", true],
		["gf", "wormhole_daemons_of_war", "Fatigue Debuff", "Mind Control", "effect", "fatigue"],
		["gf", "ratmen_clans", "Hazardous", "Hazardous", "ap", 4],
		["gf", "goblin_reclaimers", "Instinctive", "Instinctive", "hit_bonus", 1],
		["gf", "eternal_dynasty", "Vengeance", "Vengeance", "hit_bonus_per_marker", 1],
		["gf", "alien_hives", "Self-Destruct", "Self-Destruct", "trigger", "death_in_melee_or_post_m"],
		["gf", "high_elf_fleets", "Unwieldy", "Unwieldy", "strikes_last", true],
		["aof", "rift_daemons_of_war", "Reckless Piercing", "Reckless Piercing", "roll_target", 2],
		["aof", "war_disciples", "Bloodthirsty Fighter", "Bloodthirsty Fighter", "melee_only", true],
		["aof", "dark_elves", "Retreating Strike", "Ravage", "trigger", "post_melee_move"],
	]
	for c in cases:
		var entry := RulesRegistry.lookup(str(c[0]), str(c[1]), str(c[2]))
		assert_str(str(entry.get("primitive", ""))) \
			.override_failure_message("%s/%s/%s lost its primitive" % [c[0], c[1], c[2]]).is_equal(str(c[3]))
		var params: Dictionary = entry.get("params", {})
		# JSON numbers parse as float — compare with the ".0" stripped so 2 == 2.0.
		assert_str(str(params.get(str(c[4]))).trim_suffix(".0")) \
			.override_failure_message("%s/%s/%s param %s" % [c[0], c[1], c[2], c[4]]).is_equal(str(c[5]).trim_suffix(".0"))


## Wave A: the alias layer resolves the flipped rules through unit_rules_of_primitive (the seam
## every resolver queries) — one book-true unit per family leg.
func test_wave_a_unit_primitive_resolution() -> void:
	var u := _unit_with(["Takedown Strike", "Vengeance", "Unwieldy"], "gf", "alien_hives")
	assert_int(RulesRegistry.unit_rules_of_primitive(u, "Takedown").size()).is_equal(1)
