Windows Registry Editor Version 5.00

; Register .otts file extension with OpenTTS
; Run this after installing OpenTTS, adjusting the path as needed.

[HKEY_CURRENT_USER\Software\Classes\.otts]
@="OpenTTS.SaveFile"

[HKEY_CURRENT_USER\Software\Classes\OpenTTS.SaveFile]
@="OpenTTS Save File"

[HKEY_CURRENT_USER\Software\Classes\OpenTTS.SaveFile\shell\open\command]
@="\"C:\\Program Files\\OpenTTS\\OpenTTS.exe\" -- \"%1\""
