# Virtual Environment
venv/
.venv/

# Runtime-Verzeichnisse
state/
output/
.bbtmp/

# R2 browser review state (maintainer's local rework flags; read by the agent, not a build asset)
rework_flags.json

# Downloaded third-party binaries / tool checkouts (e.g. realesrgan) — never committed.
_tools/

# Session-scratch / one-off experiment scripts (underscore-prefixed convention).
# The graduated, reusable tools have no leading underscore and stay versioned
# (faction_finalize.py, faction_publish.py, glb_srgb_fix.py, ...).
_*.py

# Python Cache
__pycache__/
*.pyc
*.pyo
.pytest_cache/

# IDE
.idea/
.vscode/

# Secrets (Security)
.hf_token
.gemini_key
.trellis_space
.r2_credentials

# OS
.DS_Store
