# Cloudflare R2 upload credentials for publish_manifest.py --upload-r2
# Copy to ".r2_credentials" (git-ignored) and fill in. NEVER commit the real file.
# These are BUILD-MACHINE ONLY — the public bucket needs no key for anonymous GET,
# so nothing here ever ships in the game client.
R2_ACCESS_KEY_ID=your_r2_access_key_id
R2_SECRET_ACCESS_KEY=your_r2_secret_access_key
R2_ENDPOINT=https://<your-account-id>.r2.cloudflarestorage.com
R2_BUCKET=niemandsland-models
