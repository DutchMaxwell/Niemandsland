layout_mode = 1
anchors_preset = 1
anchor_left = 1.0
anchor_right = 1.0
offset_left = -300.0
offset_bottom = 100.0
grow_horizontal = 0
text = "Niemandsland
Controls:
- WASD: Move Camera
- Q/E: Rotate Camera
- Scroll: Zoom
- Left Click: Select/Drag
- Alt + Click: Multi-Select
- Shift + Click: Measure
- R (hold): Rotate to face cursor
- Shift+R: Rotate Group (Ctrl=rev)
- 1-9: Arrange rows (on unit)
- Shift+A: Arrow (on unit)
- Ctrl+C/V/D: Copy/Paste/Dup
- L: Lock/Unlock
- G / Shift+G: Range Ring / clear
- M / Shift+M: Move Bands / clear
- P: Pin Ruler
- K / Shift+K: Clear Rulers mine/all"

